{
    "name": "procorad/procostat-reporting",
    "description": "Document reporting engine for Procorad — generates XLSX, DOCX, PPTX and PDF from a ProcostatReportData DTO.",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "laurentmeuwly",
            "email": "laurent@lmeuwly.ch",
            "homepage": "https://axonium.ch",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "Procorad\\ProcostatReporting\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Procorad\\ProcostatReporting\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Procorad\\ProcostatReporting\\ProcostatReportingServiceProvider"
            ],
            "aliases": {
                "ProcostatReporting": "Procorad\\ProcostatReporting\\Facades\\ProcostatReporting"
            }
        }
    },
    "require": {
        "php": ">=8.2",
        "barryvdh/laravel-snappy": "^1.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0",
        "phpoffice/phpspreadsheet": "^3.0",
        "symfony/process": "^7.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.15",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-laravel": "^3.2",
        "phpstan/phpstan": "^2.1",
        "larastan/larastan": "^3.8",
        "mockery/mockery": "^1.6"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/laurentmeuwly/procostat"
        }
    ],
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test",
        "lint-fix": "vendor/bin/pint"
    }
}
