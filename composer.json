{
    "name": "procorad/procostat-reporting",
    "description": "Reporting and visualization layer for PROCOSTAT statistical results.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "laurentmeuwly",
            "email": "laurent@lmeuwly.ch",
            "homepage": "https://axonium.ch",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "Procorad\\ProcostatReporting\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Procorad\\ProcostatReporting\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2",
        "procorad/procostat": "^1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.15",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-laravel": "^3.2",
        "phpstan/phpstan": "^2.1",
        "larastan/larastan": "^3.8"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/laurentmeuwly/procostat"
        }
    ],
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test",
        "lint-fix": "vendor/bin/pint"
    }
}
